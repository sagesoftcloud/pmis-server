<!--
- File name: reset_password.njk
- Program description:
- Email notif for password reset
- 
- <Code details in specific>
- 
- Module Exports:
- - reset_password.njk: Uses the base.njk then provide
- a template to be used by the mailer module to send
- notification to a user that their password was changed
-->


{% extends "./base.njk" %}

{% block content %}
    <div class="l--body">
        <img class="l--title--logo" src='cid:app-logo'/>
        <h2>
            Hello {{userObject.firstName}} {{userObject.lastName}},
        </h2>

        <h2>
        {% if message %}
            {{message}}
        {% elif not message%}
            To reset your password please click below. If you did not request to reset your password, please ignore this email.
        {% endif %}
        </h2>

        <h2 style="margin: 3%">
            <a class="btn" href="{{link}}" style="color: whitesmoke">
                Reset Password
            </a>
        </h2>
        <h2>
          This is an auto-generated message. For any concerns, please contact the System Administrator.
        </h2>
    </div>
{% endblock %}
                 