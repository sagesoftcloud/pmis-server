{% extends "./base.njk" %}

{% block content %}
    <div class="l--body">
        <div class="l--title">
            <img class="l--title--logo" src='cid:app-logo'/>
        </div>
    
        <h1>{{appData.title}}</h1>

        <h2>
            Hi, AES Admin.
        </h2>

        <h3>This email is sent to test the mailing capabilities of {{appData.title}} at {{ip}}.</h3>
    
    </div>
{% endblock %}
                 