<!--
- File name: base.njk
- Program description:
- Email base template
-
- Module Exports:
- - base.njk: Base template and style reference
- to be used by all emails sent by mailer
-->


<!DOCTYPE html>
<html lang="en">
    <head>
        <title>{{ appData.title | title }}</title>
        <style>
            body {
                color: #003333;
                margin: 0;

            }

            h1, h2, h3, h4, h5, .title-text{
                font-family: 'Yantramanav', sans-serif;
                font-weight: 400;
            }

            h3, h4, h5 {
                margin: 0;
            }

            p, label, input, a, td{
                font-family: 'Roboto', serif;
                font-size: 12px;
            }

            a {
                text-decoration: none;
                color: #ccc;
                font-family: 'Source Sans Pro', serif;
                font-size: 13px;
            }

            .fixed {
                font-family: monospace;
                display: inline;
            }


            button, a{
                cursor: pointer;
            }

            button, a:visited{
                color: whitesmoke;
            }

            .btn{
                background-color: #121F6B;
                border: none;
                color: whitesmoke;
                padding: 20px;
                text-align: center;
                text-decoration: none;
                display: inline-block;
                font-size: 20px;
                margin: 4px 2px;
                cursor: pointer;
                border-radius: 35px;
                font-family: 'Yantramanav', sans-serif;
            }
            .email{
              color: blue;
              font-size: 24px;
              cursor: pointer;
            }
            .email > a:visited{
                color: blue;
            }
            .l--confirm-button{
                text-align: center;
                width: 15%;
                margin: auto;
                margin-top: 30px;
            }

            .l--header{
                background-color: #003333;
                color: whitesmoke;
                display: flex;
                padding: 5px 10px;
                font-size: 130%;
                justify-content: space-between;
                position: fixed;
                position: fixed;
                left:0;
                right:0;
                top:0;
                z-index: 2;
                padding:20px;
            }

            .l--body{
                margin-top:50px;
                margin-bottom:80px;
                text-align: left
            }

            .l--footer {
                position: fixed;
                left:0;
                right:0;
                bottom:0;
                background-color: #003333;
                color: whitesmoke;
                padding: 2%;
                z-index: 2;
            }

            .l--title--logo{
                height: 100px;
                width: auto;
            }

            img {
                image-rendering: -moz-crisp-edges;         /* Firefox */
                image-rendering:   -o-crisp-edges;         /* Opera */
                image-rendering: -webkit-optimize-contrast;/* Webkit (non-standard naming) */
                image-rendering: crisp-edges;
                -ms-interpolation-mode: nearest-neighbor;  /* IE (non-standard property) */
            }

        </style>
    </head>

    <body>
        {% block content %}
        {% endblock %}
    </body>
</html>