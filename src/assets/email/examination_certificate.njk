<!--
- File name: examination_certificate.njk
- Program description:
- Email notif for passing the exam
- 
- <Code details in specific>
- 
- Module Exports:
- - examination_certificate.njk: Uses the base.njk then provide
- a template to be used by the mailer module to send
- notification to a user that he/she passed the exam
-->


{% extends "./base.njk" %}

{% block content %}
    <div class="l--body">
        <img class="l--title--logo" src='cid:app-logo'/>

        <h2>
            Hello {{userObject.firstName}} {{userObject.lastName}},
        </h2>

        <h2>{{message}}</h2>
        <br/>
        <h2>Attached here is your certificate.</h2>
        <br/>
        <h2>
          This is an auto-generated message. For any concerns, please contact the AES System Administrator.
        </h2>
    </div>
{% endblock %}
                 